generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url       = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  password      String?
  name          String
  phone         String?
  rollNumber    String?   @unique
  department    String?
  isAdmin       Boolean   @default(false)
  isBlocked     Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Relations
  bookings      Booking[]
  payments      Payment[]
  cabAssignments CabAssignment[]
  
  @@index([email])
  @@index([isAdmin])
}

model Trip {
  id                String   @id @default(uuid())
  title             String
  description       String?
  date              DateTime
  bookingStartTime  DateTime
  bookingEndTime    DateTime
  cancellationDeadline DateTime?
  departureTime     DateTime
  returnTime        DateTime?
  status            TripStatus @default(UPCOMING)
  totalCost         Float?
  costPerPerson     Float?
  maxBookings       Int      @default(100)
  currentBookings   Int      @default(0)
  paymentWindowOpen Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  createdBy         String
  
  // Relations
  bookings          Booking[]
  cabs              Cab[]
  payments          Payment[]
  
  @@index([date])
  @@index([status])
}

model Booking {
  id              String        @id @default(uuid())
  userId          String
  tripId          String
  status          BookingStatus @default(CONFIRMED)
  attended        Boolean       @default(false)
  cancelledAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  // Relations
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  trip            Trip          @relation(fields: [tripId], references: [id], onDelete: Cascade)
  payment         Payment?
  cabAssignment   CabAssignment?
  
  @@unique([userId, tripId])
  @@index([userId])
  @@index([tripId])
  @@index([status])
}

model Cab {
  id              String        @id @default(uuid())
  tripId          String
  vehicleType     VehicleType
  vehicleNumber   String
  driverName      String?
  driverPhone     String?
  maxCapacity     Int
  currentOccupancy Int         @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  // Relations
  trip            Trip          @relation(fields: [tripId], references: [id], onDelete: Cascade)
  assignments     CabAssignment[]
  
  @@index([tripId])
}

model CabAssignment {
  id        String   @id @default(uuid())
  cabId     String
  userId    String
  bookingId String   @unique
  seatNumber Int?
  createdAt DateTime @default(now())
  
  // Relations
  cab       Cab      @relation(fields: [cabId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  
  @@unique([cabId, seatNumber])
  @@index([cabId])
  @@index([userId])
}

model Payment {
  id            String        @id @default(uuid())
  userId        String
  tripId        String
  bookingId     String        @unique
  amount        Float
  status        PaymentStatus @default(PENDING)
  razorpayOrderId   String?
  razorpayPaymentId String?
  razorpaySignature String?
  paidAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  
  // Relations
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  trip          Trip          @relation(fields: [tripId], references: [id], onDelete: Cascade)
  booking       Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([tripId])
  @@index([status])
}

model Analytics {
  id              String   @id @default(uuid())
  month           Int
  year            Int
  totalRevenue    Float    @default(0)
  totalExpenses   Float    @default(0)
  totalTrips      Int      @default(0)
  totalBookings   Int      @default(0)
  collectedAmount Float    @default(0)
  pendingAmount   Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@unique([month, year])
  @@index([month, year])
}

enum TripStatus {
  UPCOMING
  BOOKING_OPEN
  BOOKING_CLOSED
  CAB_ASSIGNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum BookingStatus {
  CONFIRMED
  CANCELLED
  ATTENDED
  NO_SHOW
}

enum VehicleType {
  CAB
  AUTO
  TOTO
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
}
